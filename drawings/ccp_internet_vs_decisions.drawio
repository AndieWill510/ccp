<mxfile host="app.diagrams.net">
  <diagram name="Internet vs CCP">
    <mxGraphModel dx="1800" dy="900" grid="1" gridSize="10" guides="1"
      tooltips="1" connect="1" arrows="1" fold="1" page="1"
      pageScale="1" pageWidth="1800" pageHeight="900">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="left" value="The Internet&#xa;Information protocols&#xa;TCP/IP&#xa;HTTP&#xa;SMTP&#xa;Global information exchange"
        style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="200" y="200" width="600" height="420" as="geometry"/>
        </mxCell>

        <mxCell id="right" value="CCP&#xa;Decision protocols&#xa;Proposal&#xa;Challenge&#xa;Adjudication&#xa;Legitimate execution"
        style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1000" y="200" width="600" height="420" as="geometry"/>
        </mxCell>

        <mxCell id="arrow" style="endArrow=block;html=1;" edge="1" parent="1" source="left" target="right">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
